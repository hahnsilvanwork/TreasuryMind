# Get a free Groq API key at https://console.groq.com (no credit card needed)
GROQ_API_KEY=your_groq_api_key_here

# Optional — legacy Anthropic key (not used, Groq is the default AI)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional overrides
# XRPL websocket endpoint (default: Devnet). Switch if the venue network blocks it.
# XRPL_WS_URL=wss://s.devnet.rippletest.net:51233
# XRPL_EXPLORER_BASE=https://devnet.xrpl.org
# Time lock for XLS-85 escrowed repayments, in seconds (default 15 for live demos)
# ESCROW_WINDOW_SECONDS=15
